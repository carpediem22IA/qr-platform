generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Batch {
  id          String    @id @default(cuid())
  batchNumber Int       @unique
  name        String
  createdAt   DateTime  @default(now())
  printedAt   DateTime?
  qrCodes     QrCode[]
}

model QrCode {
  id           String    @id @default(cuid())
  qrNumber     Int       @unique
  token        String    @unique
  status       String    @default("ACTIVE")
  createdAt    DateTime  @default(now())
  usedAt       DateTime?
  downloadPath String
  batchId      String
  batch        Batch     @relation(fields: [batchId], references: [id])
}
